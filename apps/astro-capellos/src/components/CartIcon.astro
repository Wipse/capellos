---
interface Props {
  triggerBg?: string
  triggerIcon?: string
}

const {triggerBg = '#1e293b', triggerIcon = '#FFFFFF'} = Astro.props
---

<a
  id="cart-trigger"
  href="/winkelmandje"
  aria-label="Winkelmandje"
  class="fixed top-20 right-4 z-60 w-12 h-12 rounded-full flex items-center justify-center shadow-lg cursor-pointer"
  style={`background-color: ${triggerBg};`}
  transition:persist
>
  <svg
    width="20"
    height="20"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
    style={`color: ${triggerIcon};`}
  >
    <path d="M6 2 3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/>
    <path d="M3 6h18"/>
    <path d="M16 10a4 4 0 01-8 0"/>
  </svg>

  <!-- Count badge -->
  <span
    id="cart-count-badge"
    class="absolute -top-1 -right-1 min-w-[18px] h-[18px] px-1 rounded-full text-[10px] font-heading font-bold flex items-center justify-center hidden"
    style={`background-color: ${triggerIcon}; color: ${triggerBg};`}
    aria-live="polite"
  ></span>
</a>

<script>
  import {getCartCount} from '../lib/cart'

  function updateBadge() {
    const badge = document.getElementById('cart-count-badge')
    if (!badge) return
    const count = getCartCount()
    if (count > 0) {
      badge.textContent = count > 99 ? '99+' : String(count)
      badge.classList.remove('hidden')
    } else {
      badge.classList.add('hidden')
    }
  }

  function bounceBadge() {
    const badge = document.getElementById('cart-count-badge')
    if (!badge) return
    badge.style.transform = 'scale(1.6)'
    badge.style.transition = 'transform 0s'
    requestAnimationFrame(() => {
      badge.style.transition = 'transform 400ms cubic-bezier(.34,1.56,.64,1)'
      badge.style.transform = 'scale(1)'
    })
  }

  document.addEventListener('astro:page-load', () => {
    updateBadge()
    window.addEventListener('cart:updated', () => {
      updateBadge()
      bounceBadge()
    })
  })
</script>
