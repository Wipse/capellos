---
import Link from './Link.astro'

interface NavLink {
  label: string
  href: string
}

interface NavGroup {
  title: string
  links: NavLink[]
}

interface Props {
  textColor: string
  groups: NavGroup[]
}

const {textColor, groups} = Astro.props
---

<div class="flex flex-col items-center gap-10 md:flex-row md:items-start md:gap-16">
  {
    groups.map(({title, links}) => (
      <div class="w-full max-w-md text-center md:max-w-none md:text-left">
        <h2 class="mb-4 font-heading text-4xl font-bold md:mb-6" style={`color: ${textColor};`}>
          {title}
        </h2>
        <ul class="flex flex-col gap-3">
          {links.map(({label, href}) => (
            <li>
              <Link
                href={href}
                label={label}
                size="md"
                hover="opacity"
                class="font-body md:text-lg"
                style={`color: ${textColor};`}
              />
            </li>
          ))}
        </ul>
      </div>
    ))
  }
</div>
