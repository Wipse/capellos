---
// IMAGE: Simple image component with orientation support

interface Props {
  src: string
  alt?: string
  className?: string
}

const {src, alt, className} = Astro.props
---

<div class={`shadow-2xl ${className || ''}`}>
  <img src={src} alt={alt || ''} class="size-full rounded-md object-cover" loading="lazy" />
</div>
