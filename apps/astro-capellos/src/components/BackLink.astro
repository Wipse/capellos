---
import Icon from './Icon.astro'

interface Props {
  href: string
  label: string
  color?: string
  class?: string
}

const {href, label, color = 'currentColor', class: className} = Astro.props
---

<a
  href={href}
  class:list={[
    'group mb-6 inline-flex items-center gap-2 font-heading text-sm font-semibold tracking-widest uppercase opacity-70 transition-opacity hover:opacity-100',
    className,
  ]}
  style={`color: ${color};`}
>
  <Icon
    type="chevron-left"
    size={18}
    addedClasses="transition-transform duration-200 group-hover:-translate-x-1"
  />
  {label}
</a>
