---
/**
 * Renders a hidden SVG <clipPath> definition.
 * Apply to any element with: style="clip-path: url(#{id})"
 *
 * edges:
 *   'bottom'  — wavy bottom edge only (hero-style)
 *   'both'    — wavy top + bottom edges (section-style)
 *
 * movement:
 *   'slow'    — 14s cycle, subtle wobble
 *   'normal'  — 9s cycle
 *   'intense' — 5s cycle, aggressive morph
 */
interface Props {
  id: string
  edges?: 'bottom' | 'top' | 'both'
  movement?: 'slow' | 'normal' | 'intense'
}

const {id, edges = 'bottom', movement = 'normal'} = Astro.props

const dur = {slow: '14s', normal: '9s', intense: '5s'}[movement]

// bottom-only: clips a rectangular top, wavy bottom (~82–93% height)
const bottomP1 =
  'M0,0 L1,0 L1,0.88 C0.92,0.93 0.82,0.96 0.70,0.92 C0.58,0.88 0.52,0.82 0.40,0.85 C0.28,0.88 0.16,0.94 0,0.88 Z'
const bottomP2 =
  'M0,0 L1,0 L1,0.93 C0.92,0.88 0.82,0.84 0.71,0.88 C0.59,0.92 0.53,0.97 0.40,0.94 C0.27,0.91 0.15,0.88 0,0.93 Z'

// top-only: wavy top (~0–15%), flat bottom — for footer
const topP1 =
  'M0,0.14 C0.12,0.04 0.25,0 0.42,0.07 C0.54,0.12 0.60,0.16 0.72,0.07 C0.84,0 0.93,0.03 1,0.14 L1,1 L0,1 Z'
const topP2 =
  'M0,0.09 C0.12,0.17 0.25,0.13 0.42,0.08 C0.54,0.03 0.60,0 0.72,0.08 C0.84,0.14 0.93,0.12 1,0.09 L1,1 L0,1 Z'

// both-edges: wavy top (~4–8%) and wavy bottom (~92–96%) — less amplitude than hero
const bothP1 =
  'M0,0.05 C0.18,0.01 0.35,0.03 0.52,0.06 C0.68,0.09 0.82,0.04 1,0.05 L1,0.95 C0.82,0.99 0.65,0.97 0.48,0.94 C0.32,0.91 0.17,0.96 0,0.95 Z'
const bothP2 =
  'M0,0.08 C0.18,0.05 0.35,0.07 0.52,0.03 C0.68,0 0.82,0.07 1,0.08 L1,0.92 C0.82,0.95 0.65,0.94 0.48,0.97 C0.32,1.00 0.17,0.93 0,0.92 Z'

const p1 = edges === 'both' ? bothP1 : edges === 'top' ? topP1 : bottomP1
const p2 = edges === 'both' ? bothP2 : edges === 'top' ? topP2 : bottomP2
---

<svg
  width="0"
  height="0"
  style="position:absolute;pointer-events:none;overflow:hidden"
  aria-hidden="true"
  focusable="false"
>
  <defs>
    <clipPath id={id} clipPathUnits="objectBoundingBox">
      <path d={p1}>
        <animate
          attributeName="d"
          dur={dur}
          repeatCount="indefinite"
          calcMode="spline"
          keyTimes="0;0.5;1"
          keySplines=".4 0 .2 1;.4 0 .2 1"
          values={`${p1};${p2};${p1}`}
        />
      </path>
    </clipPath>
  </defs>
</svg>
