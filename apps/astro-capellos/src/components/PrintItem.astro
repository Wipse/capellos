---
interface Props {
  title: string
  price: number
  size: string
  imageUrl: string
  imageAlt?: string
  href?: string
  gridClass: string
}

const {title, price, size, imageUrl, imageAlt = title, href = '#', gridClass} = Astro.props
---

<article class={`${gridClass} group cursor-pointer`}>
  <a href={href}>
    <!-- Image -->
    <div class="aspect-square overflow-hidden bg-gray-100 mb-2">
      <img
        src={imageUrl}
        alt={imageAlt}
        class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
      />
    </div>

    <!-- Info -->
    <div class="flex justify-between">
      <div class="flex flex-col">
        <h3 class="font-medium text-lg">{title}</h3>
        <p class="text-gray-500 -mt-0.5">{size}</p>
      </div>
      <p class="text-lg font-medium mt-0.5">€{price.toFixed(2)}</p>
    </div>
  </a>
</article>
