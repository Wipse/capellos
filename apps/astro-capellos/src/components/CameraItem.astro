---
const { product } = Astro.props;
---

<div class="relative shrink-0 w-full h-full flex items-end justify-center px-8 py-4">
    <h3 class="text-4xl font-bold text-white z-20" style="font-family: var(--font-family-micro);">
        {product.title}
    </h3>
    <div class="absolute bottom-0 left-0 w-full h-1/3 bg-linear-to-t from-black to-transparent z-10" />
    <img 
        src={product.imageUrl || "../../public/images/frutsel.png"} 
        alt={product.title} 
        class="absolute top-0 left-0 w-full h-full object-cover rounded-lg shadow-lg mb-4 z-0" 
    />
</div>