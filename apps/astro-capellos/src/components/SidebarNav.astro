---
import Logo from './Logo.astro'
import {colorLetters} from '../utils/colorLetters'
import {getCategories} from '../queries/categories'

interface Props {
  triggerBg?: string
  triggerIcon?: string
  logoColor?: string
}

const {triggerBg = '#1e293b', triggerIcon = '#FFFFFF', logoColor = '#1e293b'} = Astro.props

const shopChars = colorLetters('Shop')
const aanvragenChars = colorLetters('Aanvragen')
const overChars = colorLetters('Over Capellos')
const contactChars = colorLetters('Contact')

const categories = await getCategories()
const shopItems = categories.map((cat) => ({
  href: `/${cat.slug}`,
  label: cat.title,
}))
---

<!-- Overlay -->
<div
  id="nav-overlay"
  class="fixed inset-0 z-40 bg-black pointer-events-none"
  style="opacity: 0;"
  aria-hidden="true"
  transition:persist
>
</div>

<!-- Sidebar -->
<aside
  id="nav-sidebar"
  class="fixed top-0 right-0 z-50 h-full w-[min(400px,100vw)] bg-white flex flex-col px-10 py-12 pointer-events-none"
  style="transform: translateX(100%);"
  aria-label="Navigatiemenu"
  aria-hidden="true"
  transition:persist
>
  <Logo width={180} height={60} color={logoColor} addedClasses="mb-14 flex-none opacity-60" />

  <nav class="flex flex-col gap-1">
    <!-- Shop (uitvouwbaar) -->
    <div class="nav-sidebar-link transition-all duration-200">
      <button
        id="shop-toggle"
        class="flex w-full gap-x-2 items-center font-heading text-3xl lg:text-4xl font-semibold uppercase text-slate-900 leading-tight py-2 cursor-pointer hover:pl-3 transition-all duration-200"
        aria-expanded="false"
      >
        <span>
          {
            shopChars.map(({char, color}) =>
              color ? <span style={`color: ${color};`}>{char}</span> : ' ',
            )
          }
        </span>
        <svg
          id="shop-chevron"
          width="28"
          height="28"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="m6 9 6 6 6-6"></path>
        </svg>
      </button>

      <div id="shop-submenu" style="height: 0; overflow: hidden;">
        <div class="flex flex-col pb-2">
          {
            shopItems.map(({href, label}) => (
              <a
                href={href}
                class="shop-submenu-link font-heading text-lg font-semibold uppercase text-slate-400 leading-tight py-1.5 pl-4 cursor-pointer hover:text-slate-900 hover:pl-6 transition-all duration-200"
                style="opacity: 0;"
              >
                {label}
              </a>
            ))
          }
        </div>
      </div>
    </div>

    <!-- Overige items -->
    <a
      href="/aanvragen"
      class="nav-sidebar-link font-heading text-3xl lg:text-4xl font-semibold uppercase text-slate-900 leading-tight py-2 cursor-pointer hover:pl-3 transition-all duration-200"
    >
      {
        aanvragenChars.map(({char, color}) =>
          color ? <span style={`color: ${color};`}>{char}</span> : ' ',
        )
      }
    </a>
    <a
      href="/over"
      class="nav-sidebar-link font-heading text-3xl lg:text-4xl font-semibold uppercase text-slate-900 leading-tight py-2 cursor-pointer hover:pl-3 transition-all duration-200"
    >
      {
        overChars.map(({char, color}) =>
          color ? <span style={`color: ${color};`}>{char}</span> : ' ',
        )
      }
    </a>
    <a
      href="/contact"
      class="nav-sidebar-link font-heading text-3xl lg:text-4xl font-semibold uppercase text-slate-900 leading-tight py-2 cursor-pointer hover:pl-3 transition-all duration-200"
    >
      {
        contactChars.map(({char, color}) =>
          color ? <span style={`color: ${color};`}>{char}</span> : ' ',
        )
      }
    </a>
  </nav>

  <div class="mt-auto flex gap-6 opacity-50">
    <a
      href="#"
      class="font-heading text-xs tracking-widest uppercase text-slate-600 hover:text-slate-900 transition-colors cursor-pointer"
      >Instagram</a
    >
    <a
      href="#"
      class="font-heading text-xs tracking-widest uppercase text-slate-600 hover:text-slate-900 transition-colors cursor-pointer"
      >Algemente Voorwaarden</a
    >
  </div>
</aside>

<!-- Trigger button -->
<button
  id="nav-trigger"
  aria-label="Menu openen"
  aria-expanded="false"
  aria-controls="nav-sidebar"
  class="fixed top-4 right-4 z-60 w-12 h-12 rounded-full flex items-center justify-center shadow-lg cursor-pointer"
  style={`background-color: ${triggerBg};`}
  transition:persist
>
  <div class="relative w-5 h-[13px] flex flex-col justify-between">
    <span
      class="nav-line block w-full h-0.5 rounded-full"
      style={`background-color: ${triggerIcon};`}></span>
    <span
      class="nav-line block w-full h-0.5 rounded-full"
      style={`background-color: ${triggerIcon};`}></span>
    <span
      class="nav-line block w-full h-0.5 rounded-full"
      style={`background-color: ${triggerIcon};`}></span>
  </div>
</button>

<script>
  import {initSidebarNav} from '../lib/animations/sidebarNav'

  document.addEventListener('astro:page-load', initSidebarNav)
</script>
