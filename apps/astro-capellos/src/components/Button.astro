---
// Button component with hover effect

interface Props {
  addedClasses?: string
}

const {addedClasses = ''} = Astro.props
---

<button
  class={`
    relative px-8 py-2 rounded-md bg-purple-200 text-[#3D245F] z-10 border-2 border-purple-400
    overflow-hidden group
    active:scale-98 transition-transform cursor-pointer
    ${addedClasses}
  `}
>
  <!-- Background circle that grows on hover -->
  <span
    class="absolute -right-full top-1/2 -translate-y-1/2
      w-full aspect-square rounded-full bg-purple-400 -z-10
      transition-all duration-700 ease-in-out
      group-hover:right-0 group-hover:scale-150"
  >
  </span>

  <span class="relative z-10 transition-colors duration-500 group-hover:text-white">
    <slot />
  </span>
</button>
