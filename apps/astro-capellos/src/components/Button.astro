---
interface Props {
  color?: string
  addedClasses?: string
  href?: string
  id?: string
}

const {color = '#1e293b', addedClasses = '', href, id} = Astro.props

const Tag = href ? 'a' : 'button'
---

<Tag
  href={href}
  id={id}
  style={`--btn-color: ${color};`}
  class={`btn-offset group relative inline-flex w-fit items-center gap-3 px-7 py-3 font-heading text-base uppercase tracking-wide cursor-pointer select-none ${addedClasses}`}
>
  <span class="relative z-10"><slot /></span>
</Tag>

<style>
  .btn-offset {
    border: 2.5px solid var(--btn-color);
    color: var(--btn-color);
    box-shadow: 4px 4px 0 var(--btn-color);
    transition: box-shadow 150ms ease, transform 150ms ease;
  }
  .btn-offset:hover {
    box-shadow: 1px 1px 0 var(--btn-color);
    transform: translate(3px, 3px);
  }
  .btn-offset:active {
    box-shadow: 0 0 0 var(--btn-color);
    transform: translate(4px, 4px);
  }
</style>
