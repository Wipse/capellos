---
import type {Product} from '../../../queries/products'

interface Props {
  products: Product[]
  categorySlug?: string
}

const {products, categorySlug} = Astro.props
---

<section class="py-section-lg">
  <div class="container mx-auto px-6 lg:px-12">
    {products.length > 0 ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-6 gap-y-12">
        {products.map((product) => {
          const size = (product.specifications?.find((s) => s._type === 'specChoice')?.options?.[0] ?? '') as string
          const slug = categorySlug ?? product.category?.slug ?? 'prints'
          const href = `/${slug}/${product.slug}`
          return (
            <article class="group cursor-pointer">
              <a href={href}>
                <div class="aspect-297/420 overflow-hidden bg-gray-100 mb-4">
                  <img
                    src={product.mainImageUrl ?? 'https://placehold.co/300x420'}
                    alt={product.mainImageAlt ?? product.name}
                    class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                    loading="lazy"
                    transition:name={`product-img-${product.slug}`}
                  />
                </div>
                <div class="flex flex-col gap-1">
                  <div class="flex items-start justify-between gap-4">
                    <h3 class="font-heading text-base font-semibold leading-snug">{product.name}</h3>
                    <p class="font-heading text-base font-semibold shrink-0">€{product.price.toFixed(2)}</p>
                  </div>
                  {size && <p class="font-body text-sm text-slate-500">{size}</p>}
                </div>
              </a>
            </article>
          )
        })}
      </div>
    ) : (
      <p class="font-body text-lg text-slate-500 text-center">
        Er zijn momenteel geen producten in deze categorie.
      </p>
    )}
  </div>
</section>
