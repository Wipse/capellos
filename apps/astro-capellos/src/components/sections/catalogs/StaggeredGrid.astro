---
import PrintItem from '../../PrintItem.astro'
import type {Product} from '../../../queries/products'
import {gridPositions, chunkProducts, buildBgItems} from '../../../lib/grids/staggeredGrid'

interface Props {
  products: Product[]
  categorySlug?: string
}

const {products, categorySlug} = Astro.props

const chunks = chunkProducts(products)
const bgItems = buildBgItems(products)
---

<section id="catalog-preview" class="relative z-10 overflow-hidden pt-section-md pb-section-xl">
  <!-- Parallax background layer -->
  <div id="catalog-preview-bg" class="pointer-events-none absolute inset-x-0 top-[-20%] bottom-0">
    {
      bgItems.map((item) => (
        <div class={`catalog-bg-${item.index} absolute aspect-297-420 opacity-30`}>
          <img
            src={item.imageUrl}
            alt=""
            class="h-full w-full object-cover"
            style="filter: blur(8px);"
          />
        </div>
      ))
    }
  </div>

  <!-- Foreground grid — one grid per chunk of 9, pattern repeats -->
  <div class="container relative mx-auto px-4 flex flex-col gap-16">
    {
      chunks.map((chunk) => (
        <div class="grid grid-cols-10 auto-rows-[80px] gap-x-4 gap-y-10 md:grid-cols-12">
          {chunk.map((product, i) => {
            const size = (product.specifications?.find((s) => s._type === 'specChoice')?.options?.[0] ?? '') as string
            return (
              <PrintItem
                gridClass={gridPositions[i]}
                title={product.name}
                price={product.price}
                imageUrl={product.mainImageUrl ?? 'https://placehold.co/300x400'}
                size={size}
                href={`/${categorySlug ?? product.category?.slug}/${product.slug}`}
                transitionName={`product-img-${product.slug}`}
              />
            )
          })}
        </div>
      ))
    }
  </div>
</section>

<script>
  import gsap from 'gsap'
  import {ScrollTrigger} from 'gsap/ScrollTrigger'

  gsap.registerPlugin(ScrollTrigger)

  document.addEventListener('astro:page-load', () => {
    const section = document.getElementById('catalog-preview')
    const bg = document.getElementById('catalog-preview-bg')
    if (!section || !bg) return

    gsap.to(bg, {
      yPercent: -15,
      ease: 'none',
      scrollTrigger: {
        trigger: section,
        start: 'top bottom',
        end: 'bottom top',
        scrub: 1.4,
      },
    })
  })

  document.addEventListener('astro:before-swap', () => {
    ScrollTrigger.getAll().forEach((t) => t.kill())
  })
</script>

<style
  is:inline
  set:html={`
  ${bgItems
    .map(
      (item) => `
    .catalog-bg-${item.index} { ${item.mobile} }
    @media (min-width: 768px) {
      .catalog-bg-${item.index} { ${item.tablet} }
    }
    @media (min-width: 1024px) {
      .catalog-bg-${item.index} { ${item.desktop} }
    }
  `,
    )
    .join('')}
`}
></style>
