---
import Heading from '../Heading.astro'

interface Props {
  title: string
  description: string
  sizes: string[]
  imageUrl: string
  material?: string
  shipping?: string
  additionalInfo?: string[]
}

const {title, description, sizes, imageUrl, material, shipping, additionalInfo} = Astro.props
---

<section id="print-detail" class="py-section-lg">
  <div class="container mx-auto px-6 lg:px-12">
    <div class="grid grid-cols-12 gap-8 items-start">
      <!-- textarea col 2–6 -->
      <div class="col-span-12 lg:col-start-2 lg:col-span-5 flex flex-col gap-10">
        <div>
          <Heading as="h2" size="md" class="mb-4 text-slate-900">Over deze print</Heading>
          <p class="font-body text-base leading-relaxed text-slate-700">
            {description}
          </p>
        </div>

        {
          material && (
            <div>
              <Heading as="h3" size="none" class="text-sm tracking-widest opacity-60 mb-3 text-slate-900">Materiaal</Heading>
              <p class="font-body text-base text-gray-700">{material}</p>
            </div>
          )
        }

        <div>
          <Heading as="h3" size="none" class="text-sm tracking-widest opacity-60 mb-3 text-slate-900">Beschikbare formaten</Heading>
          <ul class="flex flex-col gap-1">
            {
              sizes.map((size) => (
                <li class="font-body text-base text-gray-700 flex items-center gap-2">
                  <span class="inline-block w-1.5 h-1.5 rounded-full bg-slate-700 opacity-60" />
                  {size}
                </li>
              ))
            }
          </ul>
        </div>

        {
          shipping && (
            <div>
              <Heading as="h3" size="none" class="text-sm tracking-widest opacity-60 mb-3 text-slate-900">Verzending</Heading>
              <p class="font-body text-base text-gray-700">{shipping}</p>
            </div>
          )
        }

        {
          additionalInfo && additionalInfo.length > 0 && (
            <div>
              <Heading as="h3" size="none" class="text-sm tracking-widest opacity-60 mb-3 text-slate-900">Aanvullende informatie</Heading>
              <ul class="flex flex-col gap-1">
                {additionalInfo.map((item) => (
                  <li class="font-body text-base text-gray-700 flex items-center gap-2">
                    <span class="inline-block w-1.5 h-1.5 rounded-full bg-slate-900 opacity-60" />
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          )
        }
      </div>

      <!-- image col 8–11 -->
      <div class="col-span-12 lg:col-start-8 lg:col-span-4 lg:sticky lg:self-start lg:top-[12vh]">
        <!-- Outer wrapper translates, inner clips the image -->
        <div id="print-detail-travel-img" class="aspect-297/420 w-full">
          <div class="h-full w-full overflow-hidden shadow-lg bg-gray-100">
            <img
              src="https://placehold.co/300x400"
              alt={title}
              class="h-full w-full object-cover"
            />
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap'
  import {ScrollTrigger} from 'gsap/ScrollTrigger'

  gsap.registerPlugin(ScrollTrigger)

  document.addEventListener('astro:page-load', () => {
    const detailImg = document.getElementById('print-detail-travel-img')
    if (!detailImg) return

    gsap.fromTo(
      detailImg,
      {x: 120, opacity: 0},
      {
        x: 0,
        opacity: 1,
        ease: 'none',
        scrollTrigger: {
          trigger: detailImg,
          start: 'top bottom',
          end: 'center center',
          scrub: true,
        },
      },
    )
  })

  document.addEventListener('astro:before-swap', () => {
    ScrollTrigger.getAll().forEach((t) => t.kill())
  })
</script>
