---
interface Props {
  title: string
  description: string
  sizes: string[]
  imageUrl: string
}

const {title, description, sizes, imageUrl} = Astro.props
---

<section id="print-detail" class="py-section-lg">
  <div class="container mx-auto px-6 lg:px-12">
    <div class="grid grid-cols-12 gap-8 items-start">
      <!-- Tekstvelden col 2–6 -->
      <div class="col-span-12 lg:col-start-2 lg:col-span-5 flex flex-col gap-10">
        <div>
          <h2 class="font-heading text-3xl font-semibold uppercase mb-4 text-[#3D245F]">
            Over deze print
          </h2>
          <p class="font-body text-base leading-relaxed text-gray-700">
            {description}
          </p>
        </div>

        <div>
          <h3 class="font-heading text-sm tracking-widest uppercase opacity-60 mb-3 text-[#3D245F]">
            Materiaal
          </h3>
          <p class="font-body text-base text-gray-700">
            Hoogwaardig fotopapier, 250 g/m², mat afgewerkt.
          </p>
        </div>

        <div>
          <h3 class="font-heading text-sm tracking-widest uppercase opacity-60 mb-3 text-[#3D245F]">
            Beschikbare formaten
          </h3>
          <ul class="flex flex-col gap-1">
            {
              sizes.map((size) => (
                <li class="font-body text-base text-gray-700 flex items-center gap-2">
                  <span class="inline-block w-1.5 h-1.5 rounded-full bg-[#3D245F] opacity-60" />
                  {size}
                </li>
              ))
            }
          </ul>
        </div>

        <div>
          <h3 class="font-heading text-sm tracking-widest uppercase opacity-60 mb-3 text-[#3D245F]">
            Verzending
          </h3>
          <p class="font-body text-base text-gray-700">
            Gratis verzending binnen Nederland. Geleverd binnen 3–5 werkdagen, opgerold in een
            stevige koker.
          </p>
        </div>
      </div>

      <!-- Afbeelding col 8–11 -->
      <div class="col-span-12 lg:col-start-8 lg:col-span-4">
        <!-- Outer wrapper translates, inner clips the image -->
        <div id="print-detail-travel-img" class="aspect-297/420 w-full">
          <div class="h-full w-full overflow-hidden rounded-2xl shadow-lg bg-gray-100">
            <img
              src="https://placehold.co/300x400"
              alt={title}
              class="h-full w-full object-cover"
            />
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap'
  import {ScrollTrigger} from 'gsap/ScrollTrigger'

  gsap.registerPlugin(ScrollTrigger)

  const detailImg = document.getElementById('print-detail-travel-img')

  if (detailImg) {
    gsap.fromTo(
      detailImg,
      {x: 120, opacity: 0},
      {
        x: 0,
        opacity: 1,
        ease: 'none',
        scrollTrigger: {
          trigger: detailImg,
          start: 'top bottom',
          end: 'center center',
          scrub: true,
        },
      },
    )
  }
</script>
