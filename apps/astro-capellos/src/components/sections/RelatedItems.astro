---
import PrintItem from '../PrintItem.astro'
import Heading from '../Heading.astro'

interface Item {
  id: string
  title: string
  price: number
  size: string
  imageUrl: string
  href?: string
}

interface Props {
  items: Item[]
  heading?: string
  browseAllLabel?: string
  browseAllHref?: string
}

const {
  items,
  heading = 'Bekijk andere artikelen',
  browseAllLabel = 'Bekijk alles',
  browseAllHref = '#',
} = Astro.props
---

<section class="py-section-md border-t border-gray-100">
  <div class="container mx-auto px-6 lg:px-12">
    <div class="flex items-end justify-between mb-10">
      <Heading as="h2" size="sm" class="text-slate-900">{heading}</Heading>
      <a
        href={browseAllHref}
        class="font-heading text-sm tracking-widest uppercase text-slate-500 hover:text-slate-900 transition-colors"
      >
        {browseAllLabel} →
      </a>
    </div>
    <div class="grid grid-cols-2 gap-6 lg:grid-cols-4">
      {
        items.map((item) => (
          <PrintItem
            title={item.title}
            price={item.price}
            size={item.size}
            imageUrl={item.imageUrl}
            href={item.href ?? '#'}
          />
        ))
      }
    </div>
  </div>
</section>
