---
import BlobClip from '../BlobClip.astro'
import DriftBackground from '../DriftBackground.astro'
import Heading from '../Heading.astro'
import Button from '../Button.astro'

interface Props {
  backgroundColor?: string
  textColor?: string
  heading?: string
  text?: string | null
  ctaLabel?: string
  images?: {url: string; alt: string | null}[]
  showDrift?: boolean
  showBlobClip?: boolean
  sliderFadeColor?: string
}

const {
  backgroundColor = '#4BAF6E',
  textColor = '#FFFFFF',
  heading = 'Jij vraagt, ik maak',
  text = null,
  ctaLabel = 'Doe een aanvraag',
  images = [],
  showDrift = true,
  showBlobClip = true,
  sliderFadeColor,
} = Astro.props

// Fallback placeholders als er nog geen afbeeldingen zijn
const MIN = 6
const filledImages =
  images.length >= MIN
    ? images
    : [
        ...images,
        ...Array.from({length: MIN - images.length}, (_, i) => ({
          url: `https://placehold.co/300x420/cccccc/999999?text=Print+${i + 1}`,
          alt: '',
        })),
      ]

const half = Math.ceil(filledImages.length / 2)
const colA = filledImages.slice(0, half)
const colB = filledImages.slice(half)

const fadeTop = sliderFadeColor
  ? `background: linear-gradient(to bottom, ${sliderFadeColor}, transparent);`
  : ''
const fadeBottom = sliderFadeColor
  ? `background: linear-gradient(to top, ${sliderFadeColor}, transparent);`
  : ''
const fadeRight = sliderFadeColor
  ? `background: linear-gradient(to right, ${sliderFadeColor}, transparent);`
  : ''
const fadeLeft = sliderFadeColor
  ? `background: linear-gradient(to left, ${sliderFadeColor}, transparent);`
  : ''
---

{showBlobClip && <BlobClip id="aanvragenClip" edges="both" movement="slow" amplitude="sm" />}

<section
  id="aanvragen-cta"
  class={`relative overflow-hidden${showBlobClip ? ' has-blob-clip' : ''}`}
  style={`background-color: ${backgroundColor};`}
>
  {showDrift && <DriftBackground />}

  <!-- ── MOBILE layout: flex column, slider-row / text / slider-row ── -->
  <div class="flex flex-col lg:hidden">

    <!-- Slider rij A: horizontaal -->
    <div class="relative overflow-hidden h-40 pointer-events-none">
      <div class="slider-track-h slider-left flex flex-row gap-3 h-full">
        {[...colA, ...colA].map((img) => (
          <div class="h-full aspect-297/420 overflow-hidden rounded-lg shrink-0">
            <img src={img.url} alt={img.alt ?? ''} class="h-full w-full object-cover" loading="lazy" />
          </div>
        ))}
      </div>
      {sliderFadeColor && (
        <>
          <div class="pointer-events-none absolute inset-y-0 left-0 w-16 z-10" style={fadeRight}></div>
          <div class="pointer-events-none absolute inset-y-0 right-0 w-16 z-10" style={fadeLeft}></div>
        </>
      )}
    </div>

    <!-- Tekst -->
    <div class="relative px-6 py-12 flex flex-col gap-6">
      <Heading as="h2" size="lg" style={`color: ${textColor};`}>{heading}</Heading>
      {text && (
        <p class="font-body text-base leading-relaxed opacity-85" style={`color: ${textColor};`}>
          {text}
        </p>
      )}
      <Button href="/aanvragen" color={textColor} addedClasses="mt-2">
        {ctaLabel}
      </Button>
    </div>

    <!-- Slider rij B: horizontaal tegengesteld -->
    <div class="relative overflow-hidden h-40 pointer-events-none">
      <div class="slider-track-h slider-right flex flex-row gap-3 h-full">
        {[...colB, ...colB].map((img) => (
          <div class="h-full aspect-297/420 overflow-hidden rounded-lg shrink-0">
            <img src={img.url} alt={img.alt ?? ''} class="h-full w-full object-cover" loading="lazy" />
          </div>
        ))}
      </div>
      {sliderFadeColor && (
        <>
          <div class="pointer-events-none absolute inset-y-0 left-0 w-16 z-10" style={fadeRight}></div>
          <div class="pointer-events-none absolute inset-y-0 right-0 w-16 z-10" style={fadeLeft}></div>
        </>
      )}
    </div>

  </div>

  <!-- ── DESKTOP layout: absolute vertical sliders rechts, tekst links ── -->
  <div class="hidden lg:block" style="height: 120vh;">

    <!-- Sliders: absolute, full height, right half -->
    <div class="absolute inset-y-0 right-0 w-1/2 grid grid-cols-2 gap-3 overflow-hidden pointer-events-none">

      <!-- Column A: scrolls up -->
      <div class="slider-col relative overflow-hidden">
        <div class="slider-track slider-up flex flex-col gap-3">
          {[...colA, ...colA].map((img) => (
            <div class="aspect-297/420 w-full overflow-hidden rounded-lg shrink-0">
              <img src={img.url} alt={img.alt ?? ''} class="h-full w-full object-cover" loading="lazy" />
            </div>
          ))}
        </div>
        {sliderFadeColor && (
          <>
            <div class="pointer-events-none absolute inset-x-0 top-0 h-32 z-10" style={fadeTop}></div>
            <div class="pointer-events-none absolute inset-x-0 bottom-0 h-32 z-10" style={fadeBottom}></div>
          </>
        )}
      </div>

      <!-- Column B: scrolls down -->
      <div class="slider-col relative overflow-hidden">
        <div class="slider-track slider-down flex flex-col gap-3">
          {[...colB, ...colB].map((img) => (
            <div class="aspect-297/420 w-full overflow-hidden rounded-lg shrink-0">
              <img src={img.url} alt={img.alt ?? ''} class="h-full w-full object-cover" loading="lazy" />
            </div>
          ))}
        </div>
        {sliderFadeColor && (
          <>
            <div class="pointer-events-none absolute inset-x-0 top-0 h-32 z-10" style={fadeTop}></div>
            <div class="pointer-events-none absolute inset-x-0 bottom-0 h-32 z-10" style={fadeBottom}></div>
          </>
        )}
      </div>
    </div>

    <!-- Text content: centered left half -->
    <div class="container relative mx-auto px-12 py-section-xl h-full flex items-center">
      <div class="w-1/2 flex flex-col gap-6">
        <Heading as="h2" size="lg" style={`color: ${textColor};`}>{heading}</Heading>
        {text && (
          <p class="font-body text-base leading-relaxed max-w-lg opacity-85" style={`color: ${textColor};`}>
            {text}
          </p>
        )}
        <Button href="/aanvragen" color={textColor} addedClasses="mt-2">
          {ctaLabel}
        </Button>
      </div>
    </div>

  </div>
</section>

<script>
  import gsap from 'gsap'

  document.addEventListener('astro:page-load', () => {
    const tweens: gsap.core.Tween[] = []

    // Vertical (desktop)
    document.querySelectorAll<HTMLElement>('.slider-up').forEach((track) => {
      const height = track.scrollHeight / 2
      tweens.push(gsap.fromTo(track, {y: 0}, {y: -height, duration: 30, ease: 'none', repeat: -1}))
    })
    document.querySelectorAll<HTMLElement>('.slider-down').forEach((track) => {
      const height = track.scrollHeight / 2
      tweens.push(gsap.fromTo(track, {y: -height}, {y: 0, duration: 30, ease: 'none', repeat: -1}))
    })

    // Horizontal (mobile)
    document.querySelectorAll<HTMLElement>('.slider-left').forEach((track) => {
      const width = track.scrollWidth / 2
      tweens.push(gsap.fromTo(track, {x: 0}, {x: -width, duration: 20, ease: 'none', repeat: -1}))
    })
    document.querySelectorAll<HTMLElement>('.slider-right').forEach((track) => {
      const width = track.scrollWidth / 2
      tweens.push(gsap.fromTo(track, {x: -width}, {x: 0, duration: 20, ease: 'none', repeat: -1}))
    })

    // Scroll boost alleen op desktop — op mobile is het een onnodige performance-hit
    let scrollTimer: ReturnType<typeof setTimeout>
    const onScroll = () => {
      tweens.forEach((t) => t.timeScale(4))
      clearTimeout(scrollTimer)
      scrollTimer = setTimeout(() => {
        tweens.forEach((t) => gsap.to(t, {timeScale: 1, duration: 0.8, ease: 'power2.out'}))
      }, 100)
    }
    if (window.innerWidth >= 1024) {
      window.addEventListener('scroll', onScroll, {passive: true})
    }

    const section = document.getElementById('aanvragen-cta')
    if (section) {
      ;(section as any)._cleanup = () => {
        window.removeEventListener('scroll', onScroll)
        clearTimeout(scrollTimer)
        tweens.forEach((t) => t.kill())
      }
    }
  })

  document.addEventListener('astro:before-swap', () => {
    ;(document.getElementById('aanvragen-cta') as any)?._cleanup?.()
  })
</script>

<style>
  #aanvragen-cta.has-blob-clip {
    clip-path: url(#aanvragenClip);
  }

  @media (max-width: 639px) {
    #aanvragen-cta.has-blob-clip {
      clip-path: url(#aanvragenClip-mobile);
    }
  }

  .slider-up,
  .slider-down,
  .slider-left,
  .slider-right {
    will-change: transform;
    backface-visibility: hidden;
  }

  @media (prefers-reduced-motion: reduce) {
    .slider-up, .slider-down, .slider-left, .slider-right {
      animation: none !important;
    }
  }
</style>
