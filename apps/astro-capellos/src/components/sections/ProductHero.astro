---
import BlobClip from '../BlobClip.astro'
import DriftBackground from '../DriftBackground.astro'
import Icon from '../Icon.astro'
import BackLink from '../BackLink.astro'
import Heading from '../Heading.astro'

interface Props {
  title: string
  price: number
  sizes: string[]
  description: string
  category: string
  imageUrl?: string
  backgroundColor?: string
  textColor?: string
  transitionName?: string
  productId: string
  productSlug: string
  categorySlug: string
}

const {
  title,
  price,
  sizes,
  description,
  category,
  imageUrl,
  backgroundColor = '#4BAF6E',
  textColor = '#FFFFFF',
  transitionName,
  productId,
  productSlug,
  categorySlug,
} = Astro.props
---

<BlobClip id="productDetailClip" edges="bottom" movement="normal" aplitude="lg" />

<section
  id="product-detail-hero"
  class="relative min-h-dvh pt-section-md pb-section-xl"
  style={`background-color: ${backgroundColor};`}
>
  <DriftBackground />

  <div class="container relative mx-auto px-6 lg:px-12">
    <BackLink href={`/${categorySlug}`} label={`Terug naar ${category}`} color={textColor} />

    <div class="grid grid-cols-1 gap-10 justify-items-center lg:justify-items-start lg:grid-cols-12 lg:gap-20 lg:items-start">
      <!-- Image -->
      <div
        id="product-hero-img"
        class="group lg:col-start-2 lg:col-span-4 relative mx-auto w-full max-w-[260px] sm:max-w-sm lg:max-w-none"
      >
        <div
          class="absolute -inset-3 rounded-3xl opacity-20 blur-xl"
          style={`background-color: ${textColor};`}
        >
        </div>
        <div class="relative aspect-297/420 w-full overflow-hidden shadow-2xl">
          <img
            src={imageUrl ?? 'https://placehold.co/300x400'}
            alt={title}
            class="h-full w-full object-cover"
            transition:name={transitionName}
          />
        </div>
      </div>

      <!-- Product info -->
      <div class="flex flex-col items-center text-center lg:items-start lg:text-left lg:col-start-6 lg:col-span-6 lg:pt-4">
        <!-- Label -->
        <p class="font-heading tracking-widest uppercase opacity-70" style={`color: ${textColor};`}>
          {category}
        </p>

        <!-- Title — h1: dit is de enige h1 op de printdetailpagina -->
        <Heading as="h1" style={`color: ${textColor};`}>{title}</Heading>

        <!-- Price -->
        <p class="mt-4 text-3xl font-extrabold" style={`color: ${textColor};`}>
          €{price.toFixed(2)}
        </p>

        <!-- Divider -->
        <div class="mt-6 h-px w-full opacity-20" style={`background-color: ${textColor};`}></div>

        <!-- Size selector -->
        <div class="mt-6">
          <p
            class="font-heading text-xs tracking-widest uppercase opacity-70 mb-3"
            style={`color: ${textColor};`}
          >
            Formaat
          </p>
          <div class="flex flex-wrap gap-3 justify-center lg:justify-start">
            {
              sizes.map((size, i) => (
                <button
                  class="size-selector-btn font-heading text-sm font-semibold tracking-wider uppercase px-5 py-2 border transition-colors border-white/30 hover:border-current hover:bg-white/10 cursor-pointer"
                  data-selected={i === 0 ? 'true' : 'false'}
                  style={`color: ${textColor};`}
                >
                  {size}
                </button>
              ))
            }
          </div>
        </div>

        <!-- Description -->
        <p
          class="mt-6 font-body text-base leading-relaxed opacity-85"
          style={`color: ${textColor};`}
        >
          {description}
        </p>

        <!-- CTA -->
        <button
          id="add-to-cart-btn"
          data-product-id={productId}
          data-product-slug={productSlug}
          data-product-title={title}
          data-product-price={price}
          data-product-image={imageUrl ?? ''}
          data-category-slug={categorySlug}
          class="mt-8 inline-flex w-fit items-center justify-center gap-3 px-8 py-4 font-heading text-sm font-semibold tracking-widest uppercase transition-all hover:gap-5 cursor-pointer active:scale-95 transition-transform"
          style={`background-color: ${textColor}; color: ${backgroundColor};`}
        >
          <span id="add-to-cart-label">Bestel nu</span>
          <span id="add-to-cart-icon"><Icon type="chevron-right" size={16} /></span>
        </button>
      </div>
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap'
  import {ScrollTrigger} from 'gsap/ScrollTrigger'
  import {addToCart, isInCart} from '../../lib/cart'
  import {flyToCart} from '../../lib/animations/flyToCart'

  gsap.registerPlugin(ScrollTrigger)

  document.addEventListener('astro:page-load', () => {
    const heroImg = document.getElementById('product-hero-img')
    if (!heroImg) return

    if (window.innerWidth >= 1024) {
      gsap.to(heroImg, {
        x: -120,
        opacity: 0,
        ease: 'none',
        scrollTrigger: {
          trigger: heroImg,
          start: 'center center',
          end: 'bottom top',
          scrub: true,
        },
      })
    }

    // Add to cart
    const btn = document.getElementById('add-to-cart-btn') as HTMLButtonElement | null
    const label = document.getElementById('add-to-cart-label')
    if (!btn || !label) return

    const icon = document.getElementById('add-to-cart-icon')

    const setInCartState = () => {
      label.textContent = 'Al in winkelmandje ✓'
      if (icon) icon.style.display = 'none'
      btn.disabled = true
      btn.style.opacity = '0.6'
      btn.style.cursor = 'default'
    }

    // Check on load if already in cart
    if (isInCart(btn.dataset.productId!)) {
      setInCartState()
    }

    // Read active selected size
    const getSizeButtons = () =>
      document.querySelectorAll<HTMLButtonElement>('.size-selector-btn')

    // Size selector interactivity
    getSizeButtons().forEach((sizeBtn) => {
      sizeBtn.addEventListener('click', () => {
        getSizeButtons().forEach((b) => b.setAttribute('data-selected', 'false'))
        sizeBtn.setAttribute('data-selected', 'true')
      })
    })

    btn.addEventListener('click', () => {
      if (btn.disabled) return

      const selectedSize =
        Array.from(getSizeButtons()).find((b) => b.getAttribute('data-selected') === 'true')
          ?.textContent?.trim() ?? ''

      const imgEl = heroImg.querySelector('img') as HTMLImageElement

      addToCart({
        id: btn.dataset.productId!,
        slug: btn.dataset.productSlug!,
        title: btn.dataset.productTitle!,
        price: parseFloat(btn.dataset.productPrice!),
        imageUrl: btn.dataset.productImage!,
        categorySlug: btn.dataset.categorySlug!,
        size: selectedSize,
      })

      flyToCart(imgEl ?? btn, () => {
        setInCartState()
      })
    })
  })

  document.addEventListener('astro:before-swap', () => {
    ScrollTrigger.getAll().forEach((t) => t.kill())
  })
</script>

<style>
  #product-detail-hero {
    clip-path: url(#productDetailClip);
  }

  .size-selector-btn[data-selected='true'] {
    border-color: currentColor;
    background-color: rgba(255, 255, 255, 0.2);
  }

  @media (max-width: 639px) {
    #product-detail-hero {
      clip-path: url(#productDetailClip-mobile);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #product-detail-hero {
      clip-path: polygon(0% 0%, 100% 0%, 100% 88%, 83% 96%, 50% 88%, 17% 80%, 0% 88%);
    }
  }
</style>
