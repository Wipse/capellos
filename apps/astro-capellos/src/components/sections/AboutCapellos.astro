---
import BlobClip from '../BlobClip.astro'
import Logo from '../Logo.astro'
import CategoryNavItem from '../CategoryNavItem.astro'
import DriftBackground from '../DriftBackground.astro'
import Icon from '../Icon.astro'

interface Category {
  label: string
  title: string
  href: string
  imageUrl: string
}

interface Props {
  backgroundColor?: string
  textColor?: string
}

const {backgroundColor = '#4BAF6E', textColor = '#FFFFFF'} = Astro.props

// Placeholder categories — will come from Sanity
const categories: Category[] = [
  {label: 'Shop', title: 'Kleding', href: '/', imageUrl: '/images/frutsel.png'},
  {label: 'Shop', title: 'Prints', href: '/prints', imageUrl: '/images/frutsel.png'},
  {label: 'Shop', title: 'Sieraden', href: '#', imageUrl: '/images/frutsel.png'},
  {label: 'Jij vraagt ik maak!', title: 'Aanvragen', href: '#', imageUrl: '/images/frutsel.png'},
]
---

<BlobClip id="aboutClip" edges="both" movement="slow" amplitude="sm" />

<section
  id="about-capellos"
  class="relative -mt-20 pt-section-xl pb-section-2xl min-[550px]:pb-section-xl"
  style={`background-color: ${backgroundColor}; --about-text: ${textColor}; --about-bg: ${backgroundColor};`}
>
  <DriftBackground />

  <!-- Content -->
  <div class="container relative mx-auto px-6 text-center lg:px-12 lg:text-left">
    <div class="grid grid-cols-1 gap-12 lg:grid-cols-[2fr_3fr] lg:gap-20">
      <!-- Left: category navigation -->
      <nav
        aria-label="Categorieën"
        class="order-2 grid grid-cols-1 gap-20 min-[550px]:gap-y-12 gap-x-8 min-[550px]:grid-cols-2 lg:order-1 lg:flex lg:flex-col lg:items-stretch lg:gap-20"
      >
        {
          categories.map((cat) => (
            <CategoryNavItem
              label={cat.label}
              title={cat.title}
              href={cat.href}
              imageUrl={cat.imageUrl}
              textColor={textColor}
            />
          ))
        }
      </nav>

      <!-- Right: about text — sticky while left column scrolls past -->
      <div
        class="order-1 flex flex-col items-center lg:order-2 lg:sticky lg:items-start lg:self-start lg:top-[12vh]"
      >
        <p
          class="font-heading text-4xl font-light -mb-5 lg:text-5xl"
          style={`color: ${textColor};`}
        >
          Wat is
        </p>
        <div class="w-full max-w-md">
          <Logo color={textColor} addedClasses="w-full h-auto" />
        </div>

        <div
          class="mt-6 flex max-w-xl flex-col gap-4 font-body text-base leading-relaxed opacity-90 lg:max-w-none"
          style={`color: ${textColor};`}
        >
          <p>
            Lorem ipsum dolor sit amet, consectetur adipiscing elit. Etiam eu turpis molestie,
            dictum est a, mattis tellus. Sed dignissim, metus nec fringilla accumsan, risus sem
            sollicitudin lacus.
          </p>
          <p>
            Risus. Maecenas eget condimentum velit, sit amet feugiat lectus. Class aptent taciti
            sociosqu ad litora torquent per conubia nostra, per inceptos himenaeos.
          </p>
          <p>
            Risus. Maecenas eget condimentum velit, sit amet feugiat lectus. Class aptent taciti
            sociosqu ad litora torquent per conubia nostra, per inceptos himenaeos. Risus. Maecenas
            eget condimentum velit, sit amet feugiat lectus. Class aptent taciti sociosqu ad litora
            torquent per conubia nostra, per inceptos himenaeos.
          </p>
        </div>

        <a
          href="/over"
          class="mt-8 inline-flex w-fit items-center justify-center gap-2 border px-6 py-3 font-heading text-sm font-semibold tracking-widest uppercase transition-colors hover:opacity-80"
          style={`color: ${textColor}; border-color: ${textColor};`}
        >
          Lees meer
          <Icon type="chevron-right" size={16} />
        </a>
      </div>
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap'
  import {ScrollTrigger} from 'gsap/ScrollTrigger'

  gsap.registerPlugin(ScrollTrigger)

  document.addEventListener('astro:page-load', () => {
    const items = gsap.utils.toArray<HTMLElement>('#about-capellos nav > a')

    items.forEach((item) => {
      gsap.from(item, {
        y: 48,
        opacity: 0,
        duration: 0.7,
        ease: 'power2.out',
        scrollTrigger: {
          trigger: item,
          start: 'top 88%',
          toggleActions: 'play none play reverse',
        },
      })
    })
  })

  document.addEventListener('astro:before-swap', () => {
    ScrollTrigger.getAll().forEach((t) => t.kill())
  })
</script>

<style>
  #about-capellos {
    clip-path: url(#aboutClip);
  }

  @media (max-width: 639px) {
    #about-capellos {
      clip-path: url(#aboutClip-mobile);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #about-capellos {
      clip-path: polygon(
        0% 6%,
        17% -2%,
        50% 6%,
        83% 14%,
        100% 6%,
        100% 94%,
        83% 102%,
        50% 94%,
        17% 86%,
        0% 94%
      );
    }
  }
</style>
