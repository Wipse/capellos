---
import Logo from '../Logo.astro'
import CategoryNavItem from '../CategoryNavItem.astro'
import Icon from '../Icon.astro'
import type {Category} from '../../queries/categories'

interface Block {
  _type: string
  children: {text: string; marks?: string[]}[]
}

interface Props {
  categories: Category[]
  text?: Block[] | null
}

const {categories, text} = Astro.props
const textColor = '#1E293B'
---

<section id="about-capellos" class="relative py-section-xl bg-white">
  <!-- Content -->
  <div class="container relative mx-auto px-6 text-center lg:px-12 lg:text-left">
    <div class="grid grid-cols-1 gap-12 lg:grid-cols-[2fr_3fr] lg:gap-20">
      <!-- Left: category navigation -->
      <nav
        aria-label="Categorieën"
        class="order-2 grid grid-cols-1 gap-20 min-[550px]:gap-y-12 gap-x-8 min-[550px]:grid-cols-2 lg:order-1 lg:flex lg:flex-col lg:items-stretch lg:gap-20"
      >
        {
          categories.map((cat) => (
            <CategoryNavItem
              label="Shop"
              title={cat.title}
              href={`/${cat.slug}`}
              imageUrl={cat.imageUrl ?? 'https://placehold.co/300x400'}
              textColor={textColor}
            />
          ))
        }
      </nav>

      <!-- Right: about text — sticky while left column scrolls past -->
      <div
        class="order-1 flex flex-col items-center lg:order-2 lg:sticky lg:items-start lg:self-start lg:top-[12vh]"
      >
        <h2
          class="font-heading text-4xl font-light -mb-5 lg:text-5xl"
          style={`color: ${textColor};`}
        >
          Wat is<span class="sr-only"> Capellos</span>
        </h2>
        {/* Logo is decoratief hier — de h2 hierboven communiceert al "Wat is Capellos" */}
        <div class="w-full max-w-md" aria-hidden="true">
          <Logo color={textColor} has-colored addedClasses="w-full h-auto" />
        </div>

        {
          text && text.length > 0 && (
            <div
              class="mt-6 flex max-w-xl flex-col gap-4 font-body text-base leading-relaxed opacity-90 lg:max-w-none"
              style={`color: ${textColor};`}
            >
              {text.map((block) => (
                <p>
                  {block.children.map((span) => {
                    if (span.marks?.includes('strong')) return <strong>{span.text}</strong>
                    if (span.marks?.includes('em')) return <em>{span.text}</em>
                    return span.text
                  })}
                </p>
              ))}
            </div>
          )
        }

        <a
          href="/over"
          class="mt-8 inline-flex w-fit items-center justify-center gap-2 border px-6 py-3 font-heading text-sm font-semibold tracking-widest uppercase transition-colors hover:opacity-80"
          style={`color: ${textColor}; border-color: ${textColor};`}
        >
          Lees meer
          <Icon type="chevron-right" size={16} />
        </a>
      </div>
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap'
  import {ScrollTrigger} from 'gsap/ScrollTrigger'

  gsap.registerPlugin(ScrollTrigger)

  document.addEventListener('astro:page-load', () => {
    const items = gsap.utils.toArray<HTMLElement>('#about-capellos nav > a')

    items.forEach((item) => {
      gsap.from(item, {
        y: 48,
        opacity: 0,
        duration: 0.7,
        ease: 'power2.out',
        scrollTrigger: {
          trigger: item,
          start: 'top 88%',
          toggleActions: 'play none play reverse',
        },
      })
    })
  })

  document.addEventListener('astro:before-swap', () => {
    ScrollTrigger.getAll().forEach((t) => t.kill())
  })
</script>
