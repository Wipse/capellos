---
import PrintItem from '../PrintItem.astro'

export interface Print {
  id: string
  title: string
  price: number
  size: string
  imageUrl: string
  slug?: string
}

interface Props {
  prints: Print[]
}

const {prints} = Astro.props

// Staggered grid — mobile: 10-col, col-span-5 (2 per rij); tablet: 10-col, col-span-5 (2 per rij, ruimer); desktop: 12-col, col-span-3 (3 per rij)
const gridPositions = [
  // group 1
  'col-span-5 col-start-2 row-start-1  row-span-4   md:col-span-5 md:col-start-1 md:row-start-1   lg:col-span-3 lg:col-start-1  lg:row-start-5',
  'col-span-5 col-start-5 row-start-5  row-span-4   md:col-span-5 md:col-start-7 md:row-start-4   lg:col-span-3 lg:col-start-5  lg:row-start-1',
  'col-span-5 col-start-1 row-start-9  row-span-4   md:col-span-5 md:col-start-2 md:row-start-9   lg:col-span-3 lg:col-start-9  lg:row-start-3',
  // group 2
  'col-span-5 col-start-6 row-start-10 row-span-4   md:col-span-5 md:col-start-8 md:row-start-14   lg:col-span-3 lg:col-start-2  lg:row-start-11',
  'col-span-5 col-start-3 row-start-14 row-span-4   md:col-span-5 md:col-start-1 md:row-start-18  lg:col-span-3 lg:col-start-6  lg:row-start-9',
  'col-span-5 col-start-4 row-start-18 row-span-4   md:col-span-5 md:col-start-7 md:row-start-23  lg:col-span-3 lg:col-start-10 lg:row-start-13',
  // group 3
  'col-span-5 col-start-1 row-start-22 row-span-4   md:col-span-5 md:col-start-8 md:row-start-28  lg:col-span-3 lg:col-start-1  lg:row-start-19',
  'col-span-5 col-start-6 row-start-24 row-span-4   md:col-span-5 md:col-start-1 md:row-start-32  lg:col-span-3 lg:col-start-5  lg:row-start-17',
  'col-span-5 col-start-2 row-start-28 row-span-4   md:col-span-5 md:col-start-5 md:row-start-37  lg:col-span-3 lg:col-start-9  lg:row-start-21',
]

// 8 ghost background images — mobile, tablet and desktop positions
const bgPositions: {mobile: string; tablet: string; desktop: string}[] = [
  {
    mobile: 'top: 20%;  left: 5%;   width: 40%;',
    tablet: 'top: 19%;  left: 60%;   width: 30%;',
    desktop: 'top: 24%;  left: 1%;   width: 20%;',
  },
  {
    mobile: 'top: 28%;  right: -5%; width: 40%;',
    tablet: 'top: 30%;  left: 18%; width: 30%;',
    desktop: 'top: 32%;  left: 46%;  width: 20%;',
  },
  {
    mobile: 'top: 35%;  left: -5%;  width: 40%;',
    tablet: 'top: 38%;  left: 60%;  width: 30%;',
    desktop: 'top: 45%;  left: 75%;  width: 20%;',
  },
  {
    mobile: 'top: 46%;  right: -5%; width: 40%;',
    tablet: 'top: 48%;  right: 50%;  width: 30%;',
    desktop: 'top: 50%;  left: 2%;   width: 20%;',
  },
  {
    mobile: 'top: 57%;  left: -5%;  width: 40%;',
    tablet: 'top: 58%;  left: 30%;  width: 30%;',
    desktop: 'top: 65%;  left: 40%;  width: 20%;',
  },
  {
    mobile: 'top: 71%;  right: 5%;  width: 40%;',
    tablet: 'top: 70%;  right: 40%;  width: 30%;',
    desktop: 'top: 75%;  left: 5%;   width: 20%;',
  },
  {
    mobile: 'top: 82%;  left: 30%;  width: 40%;',
    tablet: 'top: 81%;  left: 10%;  width: 30%;',
    desktop: 'top: 82%;  left: 70%;  width: 20%;',
  },
  {
    mobile: 'top: 95%;  right: 10%; width: 40%;',
    tablet: 'top: 93%;  right: 8%;  width: 30%;',
    desktop: 'top: 95%;  left: 20%;  width: 20%;',
  },
]

const bgItems = prints.length
  ? bgPositions.map(({mobile, tablet, desktop}, i) => ({
      mobile,
      tablet,
      desktop,
      imageUrl: prints[i % prints.length].imageUrl,
      index: i,
    }))
  : []
---

<section id="catalog-preview" class="relative z-10 overflow-hidden pt-section-md pb-section-xl">
  <!-- Parallax background layer -->
  <div id="catalog-preview-bg" class="pointer-events-none absolute inset-x-0 top-[-20%] bottom-0">
    {
      bgItems.map((item) => (
        <div class={`catalog-bg-${item.index} absolute aspect-297-420 opacity-30`}>
          <img
            src={item.imageUrl}
            alt=""
            class="h-full w-full object-cover"
            style="filter: blur(8px);"
          />
        </div>
      ))
    }
  </div>

  <!-- Foreground grid -->
  <div class="container relative mx-auto px-4">
    <div class="grid grid-cols-10 auto-rows-[80px] gap-x-4 gap-y-10 md:grid-cols-12">
      {
        prints
          .slice(0, gridPositions.length)
          .map((print, i) => (
            <PrintItem
              gridClass={gridPositions[i]}
              title={print.title}
              price={print.price}
              imageUrl={print.imageUrl}
              size={print.size}
              href={print.slug ? `/prints/${print.slug}` : '#'}
            />
          ))
      }
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap'
  import {ScrollTrigger} from 'gsap/ScrollTrigger'

  gsap.registerPlugin(ScrollTrigger)

  const section = document.getElementById('catalog-preview')
  const bg = document.getElementById('catalog-preview-bg')

  if (section && bg) {
    gsap.to(bg, {
      yPercent: -15,
      ease: 'none',
      scrollTrigger: {
        trigger: section,
        start: 'top bottom',
        end: 'bottom top',
        scrub: 1.4,
      },
    })
  }
</script>

<style
  is:inline
  set:html={`
  ${bgItems
    .map(
      (item) => `
    .catalog-bg-${item.index} { ${item.mobile} }
    @media (min-width: 768px) {
      .catalog-bg-${item.index} { ${item.tablet} }
    }
    @media (min-width: 1024px) {
      .catalog-bg-${item.index} { ${item.desktop} }
    }
  `,
    )
    .join('')}
`}
></style>
