---
import BlobClip from '../BlobClip.astro'
import Logo from '../Logo.astro'
import FooterContactInfo from '../FooterContactInfo.astro'
import FooterNav from '../FooterNav.astro'
import DriftBackground from '../DriftBackground.astro'
import Link from '../Link.astro'

interface Props {
  backgroundColor?: string
  textColor?: string
}

const {backgroundColor = '#5B6FE6', textColor = '#FFFFFF'} = Astro.props

const navGroups = [
  {
    title: 'Capellos',
    links: [
      {label: 'Over Capellos', href: '/over'},
      {label: 'Contact', href: '/contact'},
      {label: 'Retour voorwaarden', href: '/retour'},
    ],
  },
  {
    title: 'Producten',
    links: [
      {label: 'Prints', href: '/prints'},
      {label: 'Kleding', href: '/kleding'},
      {label: 'Sieraden', href: '/sieraden'},
      {label: 'Aanvragen', href: '/aanvragen'},
    ],
  },
]

const legalLinks = [
  {label: 'Cookie Policy', href: '/cookies'},
  {label: 'Privacy Policy', href: '/privacy'},
  {label: 'Algemene Voorwaarden', href: '/voorwaarden'},
]
---

<BlobClip id="footerClip" edges="top" />

<footer
  id="site-footer"
  class="relative pt-section-xl pb-10"
  style={`background-color: ${backgroundColor}; --footer-text: ${textColor};`}
>
  <DriftBackground />

  <div class="container relative mx-auto px-6 text-center lg:px-12 lg:text-left">
    <!-- Top 3-column grid -->
    <div class="grid grid-cols-1 gap-10 md:grid-cols-12">
      <div class="mx-auto w-full max-w-md md:col-span-3 md:mx-0 md:max-w-none">
        <FooterContactInfo textColor={textColor} />
      </div>
      <div class="mx-auto w-full max-w-md md:col-span-6 md:col-start-6 md:mx-0 md:max-w-none">
        <FooterNav textColor={textColor} groups={navGroups} />
      </div>
    </div>

    <!-- Full-width logo -->
    <div class="mt-10 w-full md:mt-12" aria-hidden="true">
      <Logo color={textColor} addedClasses="w-full h-auto" />
    </div>

    <!-- Bottom bar -->
    <div
      class="mt-6 flex flex-col items-center gap-3 border-t pt-6 text-center md:flex-row md:items-center md:justify-between md:text-left"
      style={`border-color: ${textColor}30;`}
    >
      <p class="font-heading text-sm font-semibold" style={`color: ${textColor};`}>
        Website by Wisse Heida
      </p>
      <ul class="flex flex-wrap gap-4">
        {
          legalLinks.map(({label, href}) => (
            <li>
              <Link
                href={href}
                label={label}
                hover="underline"
                size="sm"
                style={`color: ${textColor};`}
                has-heading-font
              />
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</footer>

<style>
  #site-footer {
    clip-path: url(#footerClip);
  }

  @media (max-width: 639px) {
    #site-footer {
      clip-path: url(#footerClip-mobile);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #site-footer {
      clip-path: polygon(0% 10%, 17% 2%, 50% 10%, 83% 18%, 100% 10%, 100% 100%, 0% 100%);
    }
  }
</style>
