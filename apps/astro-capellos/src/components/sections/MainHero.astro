---
import Logo from '../Logo.astro'
import BlobClip from '../BlobClip.astro'
import DriftBackground from '../DriftBackground.astro'
import Icon from '../Icon.astro'
import Link from '../Link.astro'

interface Props {
  textColor?: string
  /** Menulinks + "Scroll" label */
  navigationTextColor?: string
  backgroundColor?: string
}

const {textColor, navigationTextColor, backgroundColor} = Astro.props

const navItems = [
  {href: '/', label: 'Shop'},
  {href: '/prints', label: 'Gepersonaliseerde Items'},
  {href: '#', label: 'Over Capellos'},
  {href: '#', label: 'Contact'},
] as const
---

<BlobClip id="heroClip" edges="bottom" movement="normal" aplitude="lg" />

<section
  id="main-hero"
  class="relative flex h-dvh min-h-[88svh] items-center justify-center px-4 py-10"
  style={`background-color: ${backgroundColor}; --hero-text: ${textColor}; --hero-nav-text: ${navigationTextColor}; --hero-background: ${backgroundColor};`}
>
  <DriftBackground id="hero-bg-layer" />

  <div
    id="hero-inner"
    class="relative z-10 flex w-full max-w-[min(92vw,56rem)] flex-col items-center will-change-transform"
  >
    <div
      id="hero-logo-wrap"
      class="hero-anim-start relative aspect-859/286 w-full max-w-[min(92vw,52rem)]"
    >
      <Logo color="#FFFFFF" addedClasses="absolute inset-0 h-full w-full" />
      <Logo
        color={textColor}
        addedClasses="absolute inset-0 top-1 left-0.5 h-full w-full"
        has-hover-colors
      />
    </div>

    <nav
      id="hero-nav"
      class="hero-anim-start mt-2 w-full max-w-3xl sm:mt-4"
      aria-label="Hoofdnavigatie"
    >
      <ul
        class="flex flex-col gap-4 md:flex-row md:flex-nowrap md:gap-0 items-center justify-center md:[&>li+li]:border-l md:[&>li+li]:border-solid md:[&>li+li]:border-(--hero-text)"
      >
        {
          navItems.map(({href, label}) => (
            <li class="md:px-6 md:first:pl-0 md:last:pr-0 sm:px-10">
              <Link
                data-hero-nav-item
                href={href}
                label={label}
                size="xl"
                hover="underline"
                has-heading-font
                underline-color="var(--hero-text)"
                class="font-semibold text-(--hero-nav-text) focus-visible:rounded-sm focus-visible:ring-2 focus-visible:ring-(--hero-nav-text)/90 focus-visible:ring-offset-2 focus-visible:ring-offset-(--hero-background)"
              />
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</section>

<!-- Sits outside the clipped section so it isn't cut off -->
<div
  id="hero-scroll-hint"
  class="scroll-hint pointer-events-none fixed bottom-5 left-1/2 z-20 -translate-x-1/2 md:bottom-10"
  style={`--hero-nav-text: ${navigationTextColor}; --hero-text: ${textColor};`}
  aria-hidden="true"
>
  <div class="scroll-hint__bounce">
    <span class="font-heading text-sm tracking-wide text-(--hero-nav-text)/80 md:text-base">
      Scroll
    </span>
    <Icon type="chevron-down" size={28} addedClasses="text-(--hero-text)" />
  </div>
</div>

<style>
  #main-hero {
    clip-path: url(#heroClip);
  }

  #hero-bg-layer {
    z-index: 0;
  }

  @media (max-width: 639px) {
    #main-hero {
      clip-path: url(#heroClip-mobile);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #main-hero {
      clip-path: polygon(0% 0%, 100% 0%, 100% 88%, 83% 96%, 50% 88%, 17% 80%, 0% 88%);
    }
  }
</style>

<script>
  import {runHeroIntro} from '../../lib/animations/heroIntro'
  import {initHeroScrollHint, initMainHeroScroll} from '../../lib/animations/mainHeroScroll'
  import {ScrollTrigger} from 'gsap/ScrollTrigger'

  document.addEventListener('astro:page-load', async () => {
    await runHeroIntro()
    document.getElementById('hero-scroll-hint')?.classList.add('scroll-hint--ready')
    initMainHeroScroll()
    initHeroScrollHint()
  })

  document.addEventListener('astro:before-swap', () => {
    ScrollTrigger.getAll().forEach((t) => t.kill())
  })
</script>
