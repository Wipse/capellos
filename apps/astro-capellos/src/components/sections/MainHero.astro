---
import Logo from '../Logo.astro'

interface Props {
  textColor?: string
  /** Menulinks + "Scroll" label */
  navigationTextColor?: string
  backgroundColor?: string
}

const {textColor, navigationTextColor, backgroundColor} = Astro.props

const navItems = [
  {href: '/', label: 'Shop'},
  {href: '/prints', label: 'Gepersonaliseerde Items'},
  {href: '#', label: 'Over Capellos'},
  {href: '#', label: 'Contact'},
] as const
---

<!-- Hidden SVG – defines the animated clip-path that gives the hero its organic bottom edge -->
<svg
  width="0"
  height="0"
  style="position:absolute;pointer-events:none;overflow:hidden"
  aria-hidden="true"
  focusable="false"
>
  <defs>
    <clipPath id="heroClip" clipPathUnits="objectBoundingBox">
      <path
        d="M0,0 L1,0 L1,0.88 C0.92,0.93 0.82,0.96 0.70,0.92 C0.58,0.88 0.52,0.82 0.40,0.85 C0.28,0.88 0.16,0.94 0,0.88 Z"
      >
        <animate
          attributeName="d"
          dur="9s"
          repeatCount="indefinite"
          calcMode="spline"
          keyTimes="0;0.5;1"
          keySplines=".4 0 .2 1;.4 0 .2 1"
          values="
            M0,0 L1,0 L1,0.88 C0.92,0.93 0.82,0.96 0.70,0.92 C0.58,0.88 0.52,0.82 0.40,0.85 C0.28,0.88 0.16,0.94 0,0.88 Z;
            M0,0 L1,0 L1,0.93 C0.92,0.88 0.82,0.84 0.71,0.88 C0.59,0.92 0.53,0.97 0.40,0.94 C0.27,0.91 0.15,0.88 0,0.93 Z;
            M0,0 L1,0 L1,0.88 C0.92,0.93 0.82,0.96 0.70,0.92 C0.58,0.88 0.52,0.82 0.40,0.85 C0.28,0.88 0.16,0.94 0,0.88 Z
          "
        />
      </path>
    </clipPath>
  </defs>
</svg>

<section
  id="main-hero"
  class="relative flex h-[88dvh] min-h-[88svh] items-center justify-center px-4 py-10"
  style={`background-color: ${backgroundColor}; --hero-text: ${textColor}; --hero-nav-text: ${navigationTextColor}; --hero-background: ${backgroundColor};`}
>
  <div
    id="hero-bg-layer"
    class="pointer-events-none absolute inset-0 overflow-hidden"
    aria-hidden="true"
  >
    <img
      src="/images/frutsel-zw.jpg"
      alt=""
      class="bg-drift h-full w-full object-cover opacity-10"
    />
  </div>

  <div
    id="hero-inner"
    class="relative z-10 flex w-full max-w-[min(92vw,56rem)] flex-col items-center will-change-transform"
  >
    <div
      id="hero-logo-wrap"
      class="hero-anim-start relative aspect-859/286 w-full max-w-[min(92vw,52rem)]"
    >
      <Logo color="#FFFFFF" addedClasses="absolute inset-0 h-full w-full" />
      <Logo color={textColor} addedClasses="absolute inset-0 top-1 left-0.5 h-full w-full" />
    </div>

    <nav
      id="hero-nav"
      class="hero-anim-start mt-2 w-full max-w-3xl sm:mt-4"
      aria-label="Hoofdnavigatie"
    >
      <ul
        class="flex flex-col gap-4 md:flex-row md:flex-nowrap md:gap-0 items-center justify-center md:[&>li+li]:border-l md:[&>li+li]:border-solid md:[&>li+li]:border-(--hero-text)"
      >
        {
          navItems.map(({href, label}) => (
            <li class="md:px-6 md:first:pl-0 md:last:pr-0 sm:px-10">
              <a
                data-hero-nav-item
                href={href}
                class:list={[
                  'relative inline-block pb-1 text-xl font-heading font-semibold text-(--hero-nav-text)',
                  "after:pointer-events-none after:absolute after:bottom-0 after:left-0 after:block after:h-0.5 after:w-full after:content-['']",
                  'after:origin-left after:scale-x-0 after:bg-(--hero-text) after:transition-transform after:duration-300 after:ease-out',
                  'hover:after:scale-x-100 focus-visible:after:scale-x-100 focus-visible:rounded-sm focus-visible:ring-2 focus-visible:ring-(--hero-nav-text)/90 focus-visible:ring-offset-2 focus-visible:ring-offset-(--hero-background)',
                ]}
              >
                {label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</section>

<!-- Sits outside the clipped section so it isn't cut off -->
<div
  id="hero-scroll-hint"
  class="scroll-hint pointer-events-none fixed bottom-5 left-1/2 z-20 -translate-x-1/2 md:bottom-10"
  style={`--hero-nav-text: ${navigationTextColor}; --hero-text: ${textColor};`}
  aria-hidden="true"
>
  <div class="scroll-hint__bounce">
    <span class="font-heading text-sm tracking-wide text-(--hero-nav-text)/80 md:text-base">
      Scroll
    </span>
    <svg
      class="h-7 w-7 text-(--hero-text)"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <path d="m6 9 6 6 6-6"></path>
    </svg>
  </div>
</div>

<style>
  #main-hero {
    clip-path: url(#heroClip);
  }

  #hero-bg-layer {
    z-index: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    #main-hero {
      /* Static polygon approximation of the blob shape */
      clip-path: polygon(
        0% 0%, 100% 0%, 100% 88%,
        92% 93%, 82% 96%, 70% 92%,
        58% 88%, 52% 82%, 40% 85%,
        28% 88%, 16% 94%, 0% 88%
      );
    }
  }
</style>

<script>
  import {scheduleHeroIntro} from '../../lib/animations/heroIntro'
  import {initHeroScrollHint, initMainHeroScroll} from '../../lib/animations/mainHeroScroll'

  async function boot() {
    await scheduleHeroIntro()
    document.getElementById('hero-scroll-hint')?.classList.add('scroll-hint--ready')
    initMainHeroScroll()
    initHeroScrollHint()
  }

  void boot()
</script>
