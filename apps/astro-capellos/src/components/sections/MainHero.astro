---
import Logo from '../Logo.astro'
import BlobClip from '../BlobClip.astro'
import DriftBackground from '../DriftBackground.astro'

interface Props {
  textColor?: string
  backgroundColor?: string
  showShadowLogo?: boolean
  enableHoverEffect?: boolean
}

const {textColor, backgroundColor, showShadowLogo = true, enableHoverEffect = true} = Astro.props
---

<BlobClip id="heroClip" edges="bottom" movement="normal" aplitude="lg" />

<section
  id="main-hero"
  class="relative flex h-dvh min-h-[88svh] items-center justify-center px-4 py-10"
  style={`background-color: ${backgroundColor}; --hero-text: ${textColor};`}
>
  {/* Hidden Header for SEO purposes */}
  <h1 class="sr-only">Capellos — Gepersonaliseerde prints en kleding</h1>

  <DriftBackground id="hero-bg-layer" />

  <div
    id="hero-inner"
    class="relative z-10 flex w-full max-w-[min(92vw,56rem)] flex-col items-center will-change-transform"
  >
    <div
      id="hero-logo-wrap"
      class="hero-anim-start relative aspect-859/286 w-full max-w-[min(92vw,52rem)] mb-30"
    >
      {showShadowLogo && <Logo color="#FFFFFF" addedClasses="absolute inset-0 h-full w-full" />}
      <Logo
        color={textColor}
        addedClasses="absolute inset-0 top-1 left-0.5 h-full w-full"
        has-hover-colors={enableHoverEffect || undefined}
      />
    </div>
  </div>
</section>

<!-- Sits outside the clipped section so it isn't cut off -->
<div
  id="hero-scroll-hint"
  class="scroll-hint pointer-events-none fixed inset-x-0 bottom-[22vh] z-20"
  aria-hidden="true"
>
  <div
    class="scroll-hint__bounce absolute left-[20%] -translate-x-1/2"
    style={`color: ${textColor};`}
  >
    <svg
      width="32"
      height="20"
      viewBox="0 0 32 20"
      fill="none"
      stroke="currentColor"
      stroke-width="2.5"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <path d="M4 4 L16 14 L28 4"></path>
    </svg>
  </div>

  <div
    class="scroll-hint__bounce absolute left-[80%] -translate-x-1/2 [animation-delay:0.45s]"
    style={`color: ${textColor};`}
  >
    <svg
      width="32"
      height="20"
      viewBox="0 0 32 20"
      fill="none"
      stroke="currentColor"
      stroke-width="2.5"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <path d="M4 4 L16 14 L28 4"></path>
    </svg>
  </div>
</div>

<style>
  #main-hero {
    clip-path: url(#heroClip);
  }

  #hero-bg-layer {
    z-index: 0;
  }

  @media (max-width: 639px) {
    #main-hero {
      clip-path: url(#heroClip-mobile);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #main-hero {
      clip-path: polygon(0% 0%, 100% 0%, 100% 88%, 83% 96%, 50% 88%, 17% 80%, 0% 88%);
    }
  }
</style>

<script>
  import {runHeroIntro} from '../../lib/animations/heroIntro'
  import {initHeroScrollHint, initMainHeroScroll} from '../../lib/animations/mainHeroScroll'
  import {ScrollTrigger} from 'gsap/ScrollTrigger'

  document.addEventListener('astro:page-load', async () => {
    await runHeroIntro()
    document.getElementById('hero-scroll-hint')?.classList.add('scroll-hint--ready')
    initMainHeroScroll()
    initHeroScrollHint()
  })

  document.addEventListener('astro:before-swap', () => {
    ScrollTrigger.getAll().forEach((t) => t.kill())
  })
</script>
