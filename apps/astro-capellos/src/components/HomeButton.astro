---
interface Props {
  triggerBg?: string
  triggerIcon?: string
}

const {triggerBg = '#1e293b', triggerIcon = '#FFFFFF'} = Astro.props
---

<a
  href="/"
  aria-label="Naar de homepage"
  class="fixed top-4 right-20 z-60 w-12 h-12 rounded-full flex items-center justify-center shadow-lg cursor-pointer"
  style={`background-color: ${triggerBg};`}
  transition:persist
>
  <svg
    width="20"
    height="20"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
    style={`color: ${triggerIcon};`}
  >
    <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
    <polyline points="9 22 9 12 15 12 15 22"/>
  </svg>
</a>
