---
// Richtextpagina's — slugs en content komen later via Sanity
// Placeholder slugs voor lokale development
import MainLayout from '../../layouts/main.astro'
import Footer from '../../components/sections/Footer.astro'

export function getStaticPaths() {
  return [
    {params: {slug: 'cookie-policy'}, props: {title: "Cookie Policy"}},
    {params: {slug: 'privacy-policy'}, props: {title: "Privacy Policy"}},
    {params: {slug: 'algemene-voorwaarden'}, props: {title: "Algemene Voorwaarden"}},
  ]
}

const {slug} = Astro.params
const {title} = Astro.props
---

<MainLayout title={`${title} | Capellos`}>
  <main class="container mx-auto px-6 py-section-lg lg:px-12 max-w-3xl">
    <h1 class="font-heading text-5xl font-semibold uppercase text-slate-900 mb-8">{title}</h1>
    <p class="font-body text-base text-slate-600">Pagina in opbouw.</p>
  </main>
  <Footer />
</MainLayout>
