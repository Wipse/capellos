---
import MainLayout from '../../layouts/main.astro'
import ProductHero from '../../components/sections/ProductHero.astro'
import ProductDetail from '../../components/sections/ProductDetail.astro'
import RelatedItems from '../../components/sections/RelatedItems.astro'
import Footer from '../../components/sections/Footer.astro'
import {getAllProductSlugs, getProductBySlug, getRelatedProducts} from '../../queries/products'
import {getCategories} from '../../queries/categories'
import ProductImages from '../../components/sections/ProductImages.astro'

export async function getStaticPaths() {
  const slugs = await getAllProductSlugs()
  return slugs.map(({slug, categorySlug}) => ({
    params: {category: categorySlug, slug},
  }))
}

const {slug} = Astro.params
const [product, categories] = await Promise.all([
  getProductBySlug(slug),
  getCategories(),
])

if (!product) return Astro.redirect('/404')

const related = await getRelatedProducts(product._id, product.category?._id ?? '')

// Specificaties mappen naar wat de components verwachten
const choiceSpec = product.specifications?.find((s) => s._type === 'specChoice' && s.label.toLowerCase().includes('grootte') || s._type === 'specChoice' && s.label.toLowerCase().includes('formaat') || s._type === 'specChoice' && s.label.toLowerCase().includes('maat'))
const sizes = (choiceSpec?.options ?? []) as string[]

const materialSpec = product.specifications?.find((s) => s._type === 'specText' && s.label.toLowerCase().includes('materiaal'))
const material = materialSpec ? String(materialSpec.value) : undefined

const additionalInfo = product.specifications
  ?.filter((s) => s._type === 'specBoolean' && s.value === true)
  .map((s) => s.label)

// Beschrijving als platte tekst
const descriptionText = product.description
  ?.map((block) => block.children?.map((c) => c.text).join(''))
  .join('\n') ?? ''

const backgroundColor = product.category?.colorHex ?? '#4BAF6E'
const textColor = product.category?.textColorHex ?? '#FFFFFF'
const categorySlug = product.category?.slug ?? Astro.params.category

const relatedItems = related.map((p) => ({
  id: p._id,
  title: p.name,
  price: p.price,
  size: (p.specifications?.find((s) => s._type === 'specChoice')?.options?.[0] ?? '') as string,
  imageUrl: p.mainImageUrl ?? 'https://placehold.co/300x400',
  href: `/${categorySlug}/${p.slug}`,
}))
---

<MainLayout title={`${product.name} | Capellos`}>
  <ProductHero
    title={product.name}
    price={product.price}
    sizes={sizes}
    description={descriptionText}
    category={product.category?.title ?? ''}
    imageUrl={product.mainImageUrl ?? undefined}
    backgroundColor={backgroundColor}
    textColor={textColor}
    transitionName={`product-img-${slug}`}
    productId={product._id}
    productSlug={product.slug}
    categorySlug={categorySlug}
  />
  <ProductDetail
    title={product.name}
    description={descriptionText}
    sizes={sizes}
    imageUrl={product.mainImageUrl ?? 'https://placehold.co/300x400'}
    material={material}
    shipping={product.shipping ?? undefined}
    additionalInfo={additionalInfo}
  />
  {product.images?.length > 0 && (
    <ProductImages images={product.images} productName={product.name} />
  )}
  {relatedItems.length > 0 && (
    <RelatedItems
      items={relatedItems}
      heading={`Meer uit ${product.category?.title ?? 'de collectie'}`}
      browseAllLabel="Bekijk alles"
      browseAllHref={`/${categorySlug}`}
    />
  )}
  <Footer categories={categories} />
</MainLayout>
