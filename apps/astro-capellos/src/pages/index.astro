---
import MainLayout from '../layouts/main.astro'
import MainHero from '../components/sections/MainHero.astro'
import {getMainHeroSettings} from '../queries/settings'

const heroSettings = await getMainHeroSettings()
---

<MainLayout title="Capellos">
  <MainHero
    textColor={heroSettings.textColorHex}
    navigationTextColor={heroSettings.navigationTextColorHex}
    backgroundColor={heroSettings.backgroundColorHex}
  />

  <main
    id="home-main"
    class="min-h-dvh bg-hero-bg px-section-md py-section-lg"
  >
    <div class="mx-auto max-w-3xl">
      <h1 class="text-capellos-purple text-3xl sm:text-4xl">
        Welkom bij Capellos
      </h1>
      <p class="mt-6 text-lg leading-relaxed text-capellos-purple/85">
        Scroll om de hero te verlaten — hier komt je homepage-content.
      </p>
    </div>
  </main>
</MainLayout>
