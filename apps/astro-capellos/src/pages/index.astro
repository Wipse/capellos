---
import MainLayout from '../layouts/main.astro'
import MainHero from '../components/sections/MainHero.astro'
import AboutCapellos from '../components/sections/AboutCapellos.astro'
import AanvragenCTA from '../components/sections/AanvragenCTA.astro'
import {getMainHeroSettings, getAboutCapellosSettings, getAanvragenSettings} from '../queries/settings'
import {getCategories} from '../queries/categories'
import Footer from '../components/sections/Footer.astro'

const [heroSettings, aboutSettings, aanvragenSettings, categories] = await Promise.all([
  getMainHeroSettings(),
  getAboutCapellosSettings(),
  getAanvragenSettings(),
  getCategories(),
])
---

<MainLayout title="Capellos">
  <MainHero
    textColor={heroSettings.textColorHex}
    backgroundColor={heroSettings.backgroundColorHex}
    showShadowLogo={heroSettings.showShadowLogo}
    enableHoverEffect={heroSettings.enableHoverEffect}
  />

  <AboutCapellos
    categories={categories}
    text={aboutSettings.text}
  />

  <AanvragenCTA
    backgroundColor={aanvragenSettings.backgroundColorHex}
    textColor={aanvragenSettings.textColorHex}
    heading={aanvragenSettings.heading}
    text={aanvragenSettings.text}
    ctaLabel={aanvragenSettings.ctaLabel}
    images={aanvragenSettings.images}
  />

  <Footer categories={categories} />
</MainLayout>
