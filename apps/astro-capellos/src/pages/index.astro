---
import MainLayout from '../layouts/main.astro'
import MainHero from '../components/sections/MainHero.astro'
import CatalogPreview from '../components/sections/catalogs/StaggeredGrid.astro'
import AboutCapellos from '../components/sections/AboutCapellos.astro'
import {getMainHeroSettings, getAboutCapellosSettings} from '../queries/settings'
import {getCategories} from '../queries/categories'
import placeholderPrints from '../data/placeholder-prints.json'
import Footer from '../components/sections/Footer.astro'

const [heroSettings, aboutSettings, categories] = await Promise.all([
  getMainHeroSettings(),
  getAboutCapellosSettings(),
  getCategories(),
])
---

<MainLayout title="Capellos">
  <MainHero
    textColor={heroSettings.textColorHex}
    backgroundColor={heroSettings.backgroundColorHex}
    showShadowLogo={heroSettings.showShadowLogo}
    enableHoverEffect={heroSettings.enableHoverEffect}
  />

  <CatalogPreview prints={placeholderPrints} />

  <AboutCapellos
    backgroundColor={aboutSettings.backgroundColorHex}
    textColor={aboutSettings.textColorHex}
    categories={categories}
    text={aboutSettings.text}
  />

  <Footer categories={categories} />
</MainLayout>
